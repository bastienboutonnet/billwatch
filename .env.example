# ── iCloud IMAP ────────────────────────────────────────────────────────────
# Use an APP-SPECIFIC PASSWORD (appleid.apple.com → Sign-In & Security →
# App-Specific Passwords). Your normal iCloud password will NOT work with 2FA.
IMAP_HOST=imap.mail.me.com
IMAP_PORT=993
IMAP_USER=you@icloud.com
IMAP_PASSWORD=abcd-efgh-ijkl-mnop
IMAP_INBOX=INBOX
# Create this mailbox in Mail. Drag a bill's email here after paying and
# BillWatch stops reminding you about it. Use the exact folder name.
IMAP_PAID_FOLDER=Betaald

# ── iCloud Calendar (CalDAV) ───────────────────────────────────────────────
CALENDAR_ENABLED=true
CALDAV_URL=https://caldav.icloud.com
# Defaults to IMAP_USER / IMAP_PASSWORD if left blank (same app password works).
CALDAV_USER=
CALDAV_PASSWORD=
# Leave blank to use your first calendar, or name a dedicated one e.g. "Bills".
CALENDAR_NAME=

# ── ntfy push ──────────────────────────────────────────────────────────────
NTFY_ENABLED=true
# Point at your self-hosted ntfy, or use https://ntfy.sh
NTFY_URL=https://ntfy.example.com
NTFY_TOPIC=studio-bills
# Only if the topic is access-protected:
NTFY_TOKEN=

# ── Behaviour ──────────────────────────────────────────────────────────────
POLL_INTERVAL=900          # seconds between inbox checks (900 = 15 min)
DEFAULT_TERM_DAYS=30       # due date fallback when the PDF has no date
REMIND_DAYS=7,3,1,0        # push this many days before due; overdue = every day
REMIND_BUFFER_DAYS=0       # set to e.g. 2 to treat the due date as 2 days earlier
TZ=Europe/Amsterdam

# ── Detection tuning (usually leave as-is) ─────────────────────────────────
CANDIDATE_MIN_SCORE=2      # below this, an email is ignored
CONFIDENT_MIN_SCORE=4      # at/above, auto-scheduled; between = "please check"
# BILL_KEYWORDS=invoice,factuur,rekening,vervaldatum,te betalen,iban,btw,nota
