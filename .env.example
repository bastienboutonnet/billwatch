# ── iCloud IMAP ────────────────────────────────────────────────────────────
# Use an APP-SPECIFIC PASSWORD (appleid.apple.com → Sign-In & Security →
# App-Specific Passwords). Your normal iCloud password will NOT work with 2FA.
IMAP_HOST=imap.mail.me.com
IMAP_PORT=993
IMAP_USER=you@icloud.com
IMAP_PASSWORD=abcd-efgh-ijkl-mnop
IMAP_INBOX=INBOX
# Create this mailbox in Mail. Drag a bill's email here after paying and
# BillWatch stops reminding you about it. Use the exact folder name.
IMAP_PAID_FOLDER=Betaald

# ── iCloud Calendar (CalDAV) ───────────────────────────────────────────────
CALENDAR_ENABLED=true
CALDAV_URL=https://caldav.icloud.com
# Defaults to IMAP_USER / IMAP_PASSWORD if left blank (same app password works).
CALDAV_USER=
CALDAV_PASSWORD=
# Leave blank to use your first calendar, or name a dedicated one e.g. "Bills".
CALENDAR_NAME=

# ── ntfy push ──────────────────────────────────────────────────────────────
NTFY_ENABLED=true
# Point at your self-hosted ntfy, or use https://ntfy.sh
NTFY_URL=https://ntfy.example.com
NTFY_TOPIC=studio-bills
# Only if the topic is access-protected:
NTFY_TOKEN=

# ── Pushover push (OPTIONAL) ───────────────────────────────────────────────
# Private by design (goes only to your devices) — a good alternative to a
# public ntfy topic for financial reminders. Get the keys at pushover.net:
# your User Key on the dashboard, and an Application API Token (Create an
# Application/API Token). Can run alongside or instead of ntfy.
PUSHOVER_ENABLED=false
PUSHOVER_TOKEN=
PUSHOVER_USER=
PUSHOVER_DEVICE=              # optional: limit to a single device name

# ── Email reminders (SMTP, OPTIONAL) ───────────────────────────────────────
# Sends the same reminders as a plain email alongside the ntfy push.
EMAIL_ENABLED=false
# iCloud: smtp.mail.me.com / 587 / starttls, log in with an app-specific
# password. Gmail: smtp.gmail.com / 587 / starttls + an app password.
SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587
SMTP_SECURITY=starttls        # starttls | ssl | none
SMTP_USER=you@icloud.com
SMTP_PASSWORD=abcd-efgh-ijkl-mnop
EMAIL_FROM=                    # defaults to SMTP_USER
EMAIL_TO=you@example.com       # comma-separated for multiple recipients

# ── Paperless-ngx companion (OPTIONAL) ─────────────────────────────────────
# Only needed if you run `python -m billwatch.companion` instead of the
# standalone IMAP pipeline (`python -m billwatch.main`). Then Paperless does the
# IMAP fetch / OCR / classification / archive and BillWatch only fills the due
# date and sends reminders. The IMAP_* / CANDIDATE_* keys above are unused here.
#
# One-time Paperless setup (in its web UI):
#   1. Create a document type named exactly PAPERLESS_INVOICE_DOC_TYPE below and a
#      mail rule (Settings → Mail) that files invoice email as that type. iCloud
#      works: imap.mail.me.com:993 SSL + an app-specific password.
#   2. Create a Date custom field named PAPERLESS_DUE_FIELD ("Due date"), and
#      (optional) a second Date field for PAPERLESS_LAST_REMINDED_FIELD.
#   3. Create tags PAPERLESS_PAID_TAG ("Paid") and PAPERLESS_REVIEW_TAG.
#   4. Make an API token: Settings → (your user) → API Auth Token.
# "Mark paid" = add the Paid tag to a document; the companion then stops.
PAPERLESS_URL=http://paperless.local:8000
PAPERLESS_TOKEN=
# Phone-reachable base for clickable push links (Tailscale MagicDNS or
# Cloudflare-tunnel host — NOT a LAN IP). Blank = reuse PAPERLESS_URL.
PAPERLESS_PUBLIC_URL=
PAPERLESS_INVOICE_DOC_TYPE=Invoice
PAPERLESS_DUE_FIELD=Due date
PAPERLESS_PAID_TAG=Paid
PAPERLESS_REVIEW_TAG=Needs review
# Optional: a Date custom field for durable "already reminded today" dedupe.
# Leave blank to dedupe in-process only (fine when run once a day).
PAPERLESS_LAST_REMINDED_FIELD=

# ── Invoice Ninja expense sync (OPTIONAL, companion only) ──────────────────
# Push confident (reviewed) invoices into Invoice Ninja as Expenses, and mark the
# expense paid once the Paperless `Paid` tag is added. One-directional.
# Setup: in Paperless add a TEXT custom field named below (stores the expense id);
# in Invoice Ninja create an API token (Settings → Account Management → API Tokens).
INVOICE_NINJA_ENABLED=false
INVOICE_NINJA_URL=https://invoiceninja.example.com
INVOICE_NINJA_TOKEN=
# Your IN company base currency; foreign expenses get an exchange_rate to it.
INVOICE_NINJA_BASE_CURRENCY=EUR
PAPERLESS_NINJA_ID_FIELD=Invoice Ninja id
# Editable text custom fields for the money. BillWatch fills them from OCR and
# reconciles the IN expense to them each cycle, so a correction here flows to IN.
# Amount = number ("12.72"), Currency = ISO code (USD/EUR/GBP), Exchange rate =
# rate to the IN base currency (blank = BillWatch refetches for the invoice date).
PAPERLESS_AMOUNT_FIELD=Amount
PAPERLESS_CURRENCY_FIELD=Currency
PAPERLESS_EXCHANGE_RATE_FIELD=Exchange rate

# ── Behaviour ──────────────────────────────────────────────────────────────
POLL_INTERVAL=900          # seconds between inbox checks (900 = 15 min)
DEFAULT_TERM_DAYS=30       # due date fallback when the PDF has no date
REMIND_DAYS=7,3,1,0        # push this many days before due; overdue = every day
REMIND_BUFFER_DAYS=0       # set to e.g. 2 to treat the due date as 2 days earlier
TZ=Europe/Amsterdam

# ── Detection tuning (usually leave as-is) ─────────────────────────────────
CANDIDATE_MIN_SCORE=2      # below this, an email is ignored
CONFIDENT_MIN_SCORE=4      # at/above, auto-scheduled; between = "please check"
# BILL_KEYWORDS=invoice,factuur,rekening,vervaldatum,te betalen,iban,btw,nota
